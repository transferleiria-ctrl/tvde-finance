# Firebase Configuration
# COPIE este arquivo para .env e preencha com seus valores do Firebase Console
# NUNCA faca commit do arquivo .env

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE

# Configurar no Firebase Console:
# 1. Acesse https://console.firebase.google.com/
# 2. Selecione seu projeto
# 3. Project Settings > General > Your apps > Web app
# 4. Copie o firebaseConfig para este arquivo
