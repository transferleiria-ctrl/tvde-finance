rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funcao para verificar se e admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'carloslucaspt2023@gmail.com';
    }
    
    // Funcao para verificar se e dono do documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Funcao para validar schema de trip
    function isValidTrip(data) {
      return data.keys().hasOnly(['date', 'value', 'distance', 'destination', 'createdAt', 'updatedAt'])
             && (data.get('date', null) is string || data.get('date', null) is null)
             && (data.get('value', null) is number || data.get('value', null) is null)
             && (data.get('distance', null) is number || data.get('distance', null) is null)
             && (data.get('destination', null) is string || data.get('destination', null) is null);
    }
    
    // Funcao para validar schema de expense
    function isValidExpense(data) {
      return data.keys().hasOnly(['date', 'value', 'category', 'description', 'createdAt', 'updatedAt'])
             && (data.get('date', null) is string || data.get('date', null) is null)
             && (data.get('value', null) is number || data.get('value', null) is null)
             && (data.get('category', null) is string || data.get('category', null) is null)
             && (data.get('description', null) is string || data.get('description', null) is null);
    }
    
    // Colecao users - cada usuario so acessa seus proprios dados
    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) || isAdmin())
                   && isValidWrite(request.resource.data, resource.data);
    }
    
    // Funcao generica de validacao de write
    function isValidWrite(newData, oldData) {
      // Previne alteracao de campos protegidos como email, role
      let forbidden = ['email', 'role', 'isAdmin'];
      return newData.keys().hasAny(forbidden) == false
             || (isAdmin() && newData.keys().hasAny(forbidden));
    }
    
    // Posts da comunidade - todos autenticados podem ler e criar
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasOnly(['authorId', 'authorName', 'content', 'likes', 'createdAt', 'authorPhoto'])
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 1000;
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 1000;
      allow delete: if request.auth != null && (resource.data.authorId == request.auth.uid || isAdmin());
    }
    
    // Parcerias - leitura publica, escrita apenas admin
    match /partnerships/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Estatisticas agregadas - leitura publica, escrita admin
    match /stats/{statId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Bloqueio total de acesso anonimo
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
